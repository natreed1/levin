{
  "manifest_version": 3,
  "name": "Analyst Ledger Capture",
  "version": "0.6.0",
  "description": "Capture research browsing into Flyleaf Tracking. Honors Active / All / Selected tab scopes.",
  "permissions": ["storage", "tabs", "webNavigation"],
  "host_permissions": [
    "https://levin.fly.dev/*",
    "http://127.0.0.1:8790/*",
    "http://localhost:8790/*",
    "http://127.0.0.1:8788/*",
    "http://localhost:8788/*",
    "https://finance.yahoo.com/*",
    "https://*.finance.yahoo.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://levin.fly.dev/*",
        "http://127.0.0.1:8790/*",
        "http://localhost:8790/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://finance.yahoo.com/*", "https://*.finance.yahoo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyst Ledger Capture"
  },
  "web_accessible_resources": [
    {
      "resources": ["picker.html", "picker.js"],
      "matches": ["https://levin.fly.dev/*", "http://127.0.0.1:8790/*", "http://localhost:8790/*"]
    }
  ]
}
