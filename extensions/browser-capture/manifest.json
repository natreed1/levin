{
  "manifest_version": 3,
  "name": "Analyst Ledger Capture",
  "version": "0.4.1",
  "description": "Capture research browsing to Analyst Ledger. Toggle sites, deep research (any https), excludes, and denylist.",
  "permissions": ["storage", "tabs", "webNavigation"],
  "host_permissions": [
    "http://127.0.0.1:8788/*",
    "http://localhost:8788/*",
    "https://finance.yahoo.com/*",
    "https://*.finance.yahoo.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://finance.yahoo.com/*", "https://*.finance.yahoo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyst Ledger Capture"
  }
}
